# Add env vars here.
# All variables must be prefixed with VITE_ to be exposed to the client.
# Example:
# VITE_APP_TITLE=CourseForge AI
# VITE_API_URL=https://api.example.com

# Supabase (required for backend)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Server (LLM) – do not prefix with VITE_; used only by Node server
# OPENAI_API_KEY=sk-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional: LLM API base URL for the Vite app (default: /api, proxied to server in dev)
# VITE_LLM_API_URL=http://localhost:3001

# Stripe (server only)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase server (for recording purchases in webhook)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: frontend origin for Stripe success/cancel URLs
# FRONTEND_URL=http://localhost:5173
